From: YYH2913 <yyh2913@qq.com>
Date: Tue, 14 Apr 2026 16:24:00 +0800
Subject: [PATCH] wifi: mt76: mt7996: fix EHT beamformer max NSS decoding

The EHT MCS/NSS support fields encode the maximum number of spatial
streams directly in bits 0-3 for Rx and bits 4-7 for Tx.

mt7996_mcu_sta_bfer_eht() subtracts 1 after extracting those values for
80/160/320 MHz operation. For a 2x2 EHT peer this reduces the maximum
NSS to 1 and programs the EHT beamformer state for a single stream,
which can cap AP-to-STA EHT downlink at NSS 1 even though the peer
advertises 2 spatial streams.

Use the decoded maximum NSS as-is.

Signed-off-by: YYH2913 <yyh2913@qq.com>

diff --git a/mt7996/mcu.c b/mt7996/mcu.c
--- a/mt7996/mcu.c
+++ b/mt7996/mcu.c
@@ -1988,8 +1988,8 @@ mt7996_mcu_sta_bfer_eht(struct ieee80211_link_sta *link_sta,
 	const struct ieee80211_sta_eht_cap *vc =
 		mt76_connac_get_eht_phy_cap(phy->mt76, vif);
 	const struct ieee80211_eht_cap_elem_fixed *ve = &vc->eht_cap_elem;
-	u8 nss_mcs = u8_get_bits(eht_nss->bw._80.rx_tx_mcs9_max_nss,
-				 IEEE80211_EHT_MCS_NSS_RX) - 1;
+	u8 nss_mcs = u8_get_bits(eht_nss->bw._80.rx_tx_mcs9_max_nss,
+				 IEEE80211_EHT_MCS_NSS_RX);
 	u8 snd_dim, sts;
 
 	bf->tx_mode = MT_PHY_TYPE_EHT_MU;
@@ -2013,8 +2013,8 @@ mt7996_mcu_sta_bfer_eht(struct ieee80211_link_sta *link_sta,
 	case IEEE80211_STA_RX_BW_160:
 		snd_dim = EHT_PHY(CAP2_SOUNDING_DIM_160MHZ_MASK, ve->phy_cap_info[2]);
 		sts = EHT_PHY(CAP1_BEAMFORMEE_SS_160MHZ_MASK, pe->phy_cap_info[1]);
-		nss_mcs = u8_get_bits(eht_nss->bw._160.rx_tx_mcs9_max_nss,
-				      IEEE80211_EHT_MCS_NSS_RX) - 1;
+		nss_mcs = u8_get_bits(eht_nss->bw._160.rx_tx_mcs9_max_nss,
+				      IEEE80211_EHT_MCS_NSS_RX);
 
 		bf->nrow_gt_bw80 = min_t(u8, snd_dim, sts);
 		bf->ncol_gt_bw80 = nss_mcs;
@@ -2023,8 +2023,8 @@ mt7996_mcu_sta_bfer_eht(struct ieee80211_link_sta *link_sta,
 		snd_dim = EHT_PHY(CAP2_SOUNDING_DIM_320MHZ_MASK, ve->phy_cap_info[2]) +
 			  (EHT_PHY(CAP3_SOUNDING_DIM_320MHZ_MASK,
 				   ve->phy_cap_info[3]) << 1);
 		sts = EHT_PHY(CAP1_BEAMFORMEE_SS_320MHZ_MASK, pe->phy_cap_info[1]);
-		nss_mcs = u8_get_bits(eht_nss->bw._320.rx_tx_mcs9_max_nss,
-				      IEEE80211_EHT_MCS_NSS_RX) - 1;
+		nss_mcs = u8_get_bits(eht_nss->bw._320.rx_tx_mcs9_max_nss,
+				      IEEE80211_EHT_MCS_NSS_RX);
 
 		bf->nrow_gt_bw80 = min_t(u8, snd_dim, sts) << 4;
 		bf->ncol_gt_bw80 = nss_mcs << 4;
